{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aftprotocol.org/schemas/draft/0.1/aft-incident.schema.json",
  "title": "AFT Incident",
  "description": "Security, fraud, scam, or policy incident record for an AFT agent.",
  "type": "object",
  "additionalProperties": false,
  "required": ["incident_id", "agent_id", "incident_type", "severity", "status", "detected_at", "reported_at", "evidence", "privacy", "crypto", "signatures"],
  "properties": {
    "incident_id": { "type": "string", "pattern": "^aft:incident:[A-Za-z0-9._:-]+$" },
    "agent_id": { "$ref": "#/$defs/agentId" },
    "principal_id": { "$ref": "#/$defs/entityId" },
    "operator_id": { "$ref": "#/$defs/entityId" },
    "incident_type": {
      "type": "string",
      "enum": ["SECURITY_INCIDENT", "KEY_COMPROMISE", "PROMPT_INJECTION_PAYMENT_ATTEMPT", "UNAUTHORIZED_PAYMENT_ATTEMPT", "IMPERSONATION", "FRAUD", "POLICY_VIOLATION"]
    },
    "severity": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] },
    "status": { "type": "string", "enum": ["REPORTED", "INVESTIGATING", "CONTAINED", "RESOLVED", "REJECTED"] },
    "detected_at": { "type": "string", "format": "date-time" },
    "reported_at": { "type": "string", "format": "date-time" },
    "resolved_at": { "type": "string", "format": "date-time" },
    "affected_keys": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kid", "key_version"],
        "properties": {
          "kid": { "type": "string", "minLength": 1 },
          "key_version": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "affected_event_window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "start": { "type": "string", "format": "date-time" },
        "end": { "type": "string", "format": "date-time" }
      }
    },
    "evidence": { "$ref": "#/$defs/evidence" },
    "privacy": { "$ref": "#/$defs/privacy" },
    "crypto": { "$ref": "#/$defs/crypto" },
    "signatures": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/signature" }
    }
  },
  "$defs": {
    "agentId": { "type": "string", "pattern": "^aft:agent:[A-Za-z0-9._:-]+$" },
    "entityId": {
      "type": "string",
      "pattern": "^(aft:(principal|owner|operator|controller|counterparty|issuer|lender|arbitrator|processor):[A-Za-z0-9._:-]+|did:[a-z0-9]+:.+)$"
    },
    "hashRef": { "type": "string", "pattern": "^sha(256|384|512):[A-Fa-f0-9]{64,128}$" },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_hashes", "redaction_status"],
      "properties": {
        "evidence_hashes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/hashRef" }
        },
        "evidence_uri": { "type": "string", "minLength": 1 },
        "redaction_status": { "type": "string", "enum": ["NONE", "REDACTED", "SELECTIVE_DISCLOSURE", "HASH_ONLY"] }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["classification", "pii_present", "retention_policy"],
      "properties": {
        "classification": { "type": "string", "enum": ["PUBLIC", "PRIVATE", "RESTRICTED", "HASH_ONLY"] },
        "pii_present": { "type": "boolean" },
        "retention_policy": { "type": "string", "minLength": 1 }
      }
    },
    "crypto": {
      "type": "object",
      "additionalProperties": false,
      "required": ["canonicalization", "digest_alg", "incident_hash", "revocation_root", "pqc_profile"],
      "properties": {
        "canonicalization": { "type": "string", "enum": ["JCS-RFC8785", "AFT-JCS-DRAFT-0.1"] },
        "digest_alg": { "type": "string", "enum": ["SHA-256", "SHA-384", "SHA-512"] },
        "incident_hash": { "$ref": "#/$defs/hashRef" },
        "revocation_root": { "$ref": "#/$defs/hashRef" },
        "pqc_profile": { "$ref": "#/$defs/pqcProfile" }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["alg", "kid", "key_version", "pqc_profile", "signature_value", "signature_created_at", "verification_method"],
      "properties": {
        "alg": { "$ref": "#/$defs/signatureAlg" },
        "kid": { "type": "string", "minLength": 1 },
        "key_version": { "type": "integer", "minimum": 1 },
        "pqc_profile": { "$ref": "#/$defs/pqcProfile" },
        "signature_value": { "type": "string", "pattern": "^[A-Za-z0-9_-]+={0,2}$" },
        "signature_created_at": { "type": "string", "format": "date-time" },
        "signature_expires_at": { "type": "string", "format": "date-time" },
        "verification_method": { "type": "string", "minLength": 1 }
      }
    },
    "signatureAlg": {
      "type": "string",
      "enum": ["aft-sig-ed25519-legacy", "aft-sig-ecdsa-p256-legacy", "aft-sig-ml-dsa", "aft-sig-slh-dsa", "aft-sig-hybrid-ed25519-ml-dsa", "aft-sig-hybrid-ecdsa-ml-dsa"]
    },
    "pqcProfile": {
      "type": "string",
      "enum": ["AFT-PQC-0", "AFT-PQC-1", "AFT-PQC-2", "AFT-PQC-3", "AFT-PQC-4", "AFT-PQC-5"]
    }
  }
}
