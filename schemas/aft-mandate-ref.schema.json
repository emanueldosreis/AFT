{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aftprotocol.org/schemas/draft/0.1/aft-mandate-ref.schema.json",
  "title": "AFT Mandate Reference",
  "description": "Reference to delegated authority used to bind AFT financial events.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mandate_id",
    "mandate_type",
    "mandate_hash",
    "principal_id",
    "agent_id",
    "scope",
    "amount_limit",
    "expiration",
    "nonce",
    "revocation",
    "signature"
  ],
  "properties": {
    "mandate_id": { "type": "string", "pattern": "^aft:mandate:[A-Za-z0-9._:-]+$" },
    "mandate_type": {
      "type": "string",
      "enum": [
        "LOW_VALUE_API_PURCHASE",
        "AP2_INTENT_MANDATE",
        "AP2_CART_MANDATE",
        "AP2_PAYMENT_MANDATE",
        "HUMAN_CONFIRMED_PAYMENT",
        "AUTONOMOUS_BUDGET",
        "RECURRING_SERVICE_PAYMENT",
        "PROCUREMENT_AUTHORITY",
        "ESCROW_RELEASE_AUTHORITY",
        "CREDIT_UTILIZATION_AUTHORITY",
        "CUSTOM"
      ]
    },
    "mandate_hash": { "$ref": "#/$defs/hashRef" },
    "principal_id": { "$ref": "#/$defs/entityId" },
    "agent_id": { "$ref": "#/$defs/agentId" },
    "scope": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "amount_limit": { "$ref": "#/$defs/amount" },
    "counterparty_constraints": {
      "type": "array",
      "items": { "$ref": "#/$defs/entityId" }
    },
    "purpose_codes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "expiration": { "type": "string", "format": "date-time" },
    "nonce": { "type": "string", "minLength": 8 },
    "replay_protection": { "type": "string", "minLength": 1 },
    "revocation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "revocation_ref"],
      "properties": {
        "status": { "type": "string", "enum": ["ACTIVE", "REVOKED", "EXPIRED", "SUSPENDED"] },
        "revocation_ref": { "type": "string", "minLength": 1 },
        "revoked_at": { "type": "string", "format": "date-time" }
      }
    },
    "external_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "signature": { "$ref": "#/$defs/signature" }
  },
  "$defs": {
    "agentId": { "type": "string", "pattern": "^aft:agent:[A-Za-z0-9._:-]+$" },
    "entityId": {
      "type": "string",
      "pattern": "^(aft:(principal|owner|operator|controller|counterparty|issuer|lender|arbitrator|processor):[A-Za-z0-9._:-]+|did:[a-z0-9]+:.+)$"
    },
    "hashRef": { "type": "string", "pattern": "^sha(256|384|512):[A-Fa-f0-9]{64,128}$" },
    "amount": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "currency"],
      "properties": {
        "value": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]{1,18})?$" },
        "currency": { "type": "string", "pattern": "^[A-Z0-9]{3,12}$" }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["alg", "kid", "key_version", "pqc_profile", "signature_value", "signature_created_at", "verification_method"],
      "properties": {
        "alg": { "$ref": "#/$defs/signatureAlg" },
        "kid": { "type": "string", "minLength": 1 },
        "key_version": { "type": "integer", "minimum": 1 },
        "pqc_profile": { "$ref": "#/$defs/pqcProfile" },
        "signature_value": { "type": "string", "pattern": "^[A-Za-z0-9_-]+={0,2}$" },
        "signature_created_at": { "type": "string", "format": "date-time" },
        "signature_expires_at": { "type": "string", "format": "date-time" },
        "verification_method": { "type": "string", "minLength": 1 }
      }
    },
    "signatureAlg": {
      "type": "string",
      "enum": ["aft-sig-ed25519-legacy", "aft-sig-ecdsa-p256-legacy", "aft-sig-ml-dsa", "aft-sig-slh-dsa", "aft-sig-hybrid-ed25519-ml-dsa", "aft-sig-hybrid-ecdsa-ml-dsa"]
    },
    "pqcProfile": {
      "type": "string",
      "enum": ["AFT-PQC-0", "AFT-PQC-1", "AFT-PQC-2", "AFT-PQC-3", "AFT-PQC-4", "AFT-PQC-5"]
    }
  }
}
