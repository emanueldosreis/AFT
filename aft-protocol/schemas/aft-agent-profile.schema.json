{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aftprotocol.org/schemas/draft/0.1/aft-agent-profile.schema.json",
  "title": "AFT Agent Financial Identity Profile",
  "description": "A financial identity profile for an autonomous or semi-autonomous agent.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "agent_id",
    "handle",
    "principal_id",
    "operator_id",
    "controller_id",
    "risk_status",
    "lifecycle_status",
    "pqc_readiness",
    "public_keys",
    "crypto_capabilities",
    "key_rotation",
    "revocation"
  ],
  "properties": {
    "agent_id": { "$ref": "#/$defs/agentId" },
    "handle": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,63}$"
    },
    "did": { "$ref": "#/$defs/did" },
    "owner_id": { "$ref": "#/$defs/entityId" },
    "principal_id": { "$ref": "#/$defs/entityId" },
    "operator_id": { "$ref": "#/$defs/entityId" },
    "controller_id": { "$ref": "#/$defs/entityId" },
    "funding_source_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/reference" },
      "default": []
    },
    "payment_instrument_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/reference" },
      "default": []
    },
    "wallet_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/walletRef" },
      "default": []
    },
    "credential_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/credentialRef" },
      "default": []
    },
    "risk_status": {
      "type": "string",
      "enum": ["UNKNOWN", "NORMAL", "WATCHLISTED", "RESTRICTED", "SUSPENDED", "REVOKED"]
    },
    "lifecycle_status": {
      "type": "string",
      "enum": ["PROPOSED", "ACTIVE", "PAUSED", "DEPRECATED", "RETIRED", "REVOKED"]
    },
    "public_keys": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/publicKey" }
    },
    "crypto_capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["signature_profiles", "kem_profiles", "hash_profiles"],
      "properties": {
        "signature_profiles": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/signatureAlg" }
        },
        "kem_profiles": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["aft-kem-ml-kem", "aft-kem-hybrid-ecdh-ml-kem"]
          }
        },
        "hash_profiles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["SHA-256", "SHA-384", "SHA-512"]
          }
        }
      }
    },
    "pqc_readiness": { "$ref": "#/$defs/pqcProfile" },
    "key_rotation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["current_key_version", "last_rotated_at", "rotation_policy"],
      "properties": {
        "current_key_version": { "type": "integer", "minimum": 1 },
        "last_rotated_at": { "type": "string", "format": "date-time" },
        "next_rotation_due_at": { "type": "string", "format": "date-time" },
        "rotation_policy": { "type": "string", "minLength": 1 },
        "compromised_kids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "revocation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "registry_ref", "latest_revocation_root"],
      "properties": {
        "status": { "type": "string", "enum": ["NOT_REVOKED", "SUSPENDED", "REVOKED"] },
        "registry_ref": { "type": "string", "minLength": 1 },
        "latest_revocation_root": { "$ref": "#/$defs/hashRef" },
        "revoked_at": { "type": "string", "format": "date-time" },
        "reason_code": { "type": "string", "minLength": 1 }
      }
    }
  },
  "$defs": {
    "agentId": {
      "type": "string",
      "pattern": "^aft:agent:[A-Za-z0-9._:-]+$"
    },
    "did": {
      "type": "string",
      "pattern": "^did:[a-z0-9]+:.+$"
    },
    "entityId": {
      "type": "string",
      "pattern": "^(aft:(principal|owner|operator|controller|counterparty|issuer):[A-Za-z0-9._:-]+|did:[a-z0-9]+:.+)$"
    },
    "hashRef": {
      "type": "string",
      "pattern": "^sha(256|384|512):[A-Fa-f0-9]{64,128}$"
    },
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref_id", "ref_type", "ref_hash"],
      "properties": {
        "ref_id": { "type": "string", "minLength": 1 },
        "ref_type": { "type": "string", "minLength": 1 },
        "ref_hash": { "$ref": "#/$defs/hashRef" },
        "issuer_id": { "$ref": "#/$defs/entityId" },
        "status": { "type": "string", "enum": ["ACTIVE", "SUSPENDED", "REVOKED", "EXPIRED"] }
      }
    },
    "walletRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["wallet_id", "wallet_type", "address_ref", "custody_model"],
      "properties": {
        "wallet_id": { "type": "string", "minLength": 1 },
        "wallet_type": { "type": "string", "enum": ["EVM", "SOLANA", "BITCOIN", "CUSTODIAL", "BANK", "OTHER"] },
        "address_ref": { "type": "string", "minLength": 1 },
        "custody_model": { "type": "string", "enum": ["AGENT_CONTROLLED", "PRINCIPAL_CONTROLLED", "CUSTODIAL", "MULTISIG", "POLICY_CONTROLLED"] },
        "limits_ref": { "$ref": "#/$defs/hashRef" }
      }
    },
    "credentialRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["credential_id", "issuer_id", "credential_hash", "status"],
      "properties": {
        "credential_id": { "type": "string", "minLength": 1 },
        "issuer_id": { "$ref": "#/$defs/entityId" },
        "credential_hash": { "$ref": "#/$defs/hashRef" },
        "schema_ref": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["ACTIVE", "SUSPENDED", "REVOKED", "EXPIRED"] },
        "expires_at": { "type": "string", "format": "date-time" }
      }
    },
    "publicKey": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kid", "alg", "key_version", "verification_method", "public_key_ref", "created_at", "status", "pqc_profile"],
      "properties": {
        "kid": { "type": "string", "minLength": 1 },
        "alg": { "$ref": "#/$defs/signatureAlg" },
        "key_version": { "type": "integer", "minimum": 1 },
        "verification_method": { "type": "string", "minLength": 1 },
        "public_key_ref": { "type": "string", "minLength": 1 },
        "created_at": { "type": "string", "format": "date-time" },
        "expires_at": { "type": "string", "format": "date-time" },
        "revoked_at": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["ACTIVE", "SUSPENDED", "REVOKED", "EXPIRED"] },
        "pqc_profile": { "$ref": "#/$defs/pqcProfile" }
      }
    },
    "signatureAlg": {
      "type": "string",
      "enum": [
        "aft-sig-ed25519-legacy",
        "aft-sig-ecdsa-p256-legacy",
        "aft-sig-ml-dsa",
        "aft-sig-slh-dsa",
        "aft-sig-hybrid-ed25519-ml-dsa",
        "aft-sig-hybrid-ecdsa-ml-dsa"
      ]
    },
    "pqcProfile": {
      "type": "string",
      "enum": ["AFT-PQC-0", "AFT-PQC-1", "AFT-PQC-2", "AFT-PQC-3", "AFT-PQC-4", "AFT-PQC-5"]
    }
  }
}
