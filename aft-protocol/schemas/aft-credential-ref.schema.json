{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aftprotocol.org/schemas/draft/0.1/aft-credential-ref.schema.json",
  "title": "AFT Credential Reference",
  "description": "Reference to a credential used by AFT without embedding private credential contents.",
  "type": "object",
  "additionalProperties": false,
  "required": ["credential_ref_id", "credential_type", "issuer_id", "subject_id", "credential_hash", "status", "issued_at", "revocation_ref", "privacy", "signature"],
  "properties": {
    "credential_ref_id": { "type": "string", "pattern": "^aft:credential:[A-Za-z0-9._:-]+$" },
    "credential_type": { "type": "string", "enum": ["VERIFIABLE_CREDENTIAL", "CERTIFICATION", "LICENSE", "PAYMENT_ATTESTATION", "RISK_ATTESTATION", "OTHER"] },
    "issuer_id": { "$ref": "#/$defs/entityId" },
    "subject_id": {
      "type": "string",
      "pattern": "^(aft:agent:[A-Za-z0-9._:-]+|aft:(principal|operator|controller|counterparty):[A-Za-z0-9._:-]+|did:[a-z0-9]+:.+)$"
    },
    "credential_hash": { "$ref": "#/$defs/hashRef" },
    "schema_ref": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["ACTIVE", "SUSPENDED", "REVOKED", "EXPIRED"] },
    "issued_at": { "type": "string", "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" },
    "revocation_ref": { "type": "string", "minLength": 1 },
    "selective_disclosure_supported": { "type": "boolean" },
    "privacy": { "$ref": "#/$defs/privacy" },
    "signature": { "$ref": "#/$defs/signature" }
  },
  "$defs": {
    "entityId": {
      "type": "string",
      "pattern": "^(aft:(principal|owner|operator|controller|counterparty|issuer|lender|arbitrator|processor):[A-Za-z0-9._:-]+|did:[a-z0-9]+:.+)$"
    },
    "hashRef": { "type": "string", "pattern": "^sha(256|384|512):[A-Fa-f0-9]{64,128}$" },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["classification", "pii_present", "retention_policy"],
      "properties": {
        "classification": { "type": "string", "enum": ["PUBLIC", "PRIVATE", "RESTRICTED", "HASH_ONLY"] },
        "pii_present": { "type": "boolean" },
        "retention_policy": { "type": "string", "minLength": 1 }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["alg", "kid", "key_version", "pqc_profile", "signature_value", "signature_created_at", "verification_method"],
      "properties": {
        "alg": { "$ref": "#/$defs/signatureAlg" },
        "kid": { "type": "string", "minLength": 1 },
        "key_version": { "type": "integer", "minimum": 1 },
        "pqc_profile": { "$ref": "#/$defs/pqcProfile" },
        "signature_value": { "type": "string", "pattern": "^[A-Za-z0-9_-]+={0,2}$" },
        "signature_created_at": { "type": "string", "format": "date-time" },
        "signature_expires_at": { "type": "string", "format": "date-time" },
        "verification_method": { "type": "string", "minLength": 1 }
      }
    },
    "signatureAlg": {
      "type": "string",
      "enum": ["aft-sig-ed25519-legacy", "aft-sig-ecdsa-p256-legacy", "aft-sig-ml-dsa", "aft-sig-slh-dsa", "aft-sig-hybrid-ed25519-ml-dsa", "aft-sig-hybrid-ecdsa-ml-dsa"]
    },
    "pqcProfile": {
      "type": "string",
      "enum": ["AFT-PQC-0", "AFT-PQC-1", "AFT-PQC-2", "AFT-PQC-3", "AFT-PQC-4", "AFT-PQC-5"]
    }
  }
}
