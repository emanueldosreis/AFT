{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aftprotocol.org/schemas/draft/0.1/aft-event.schema.json",
  "title": "AFT Event Envelope",
  "description": "Canonical signed event envelope for AFT financial trust events.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "aft_event_version",
    "event_type",
    "event_time",
    "agent_id",
    "principal_id",
    "transaction",
    "authority",
    "evidence",
    "privacy",
    "crypto",
    "signatures"
  ],
  "properties": {
    "event_id": { "type": "string", "pattern": "^aft:event:[A-Za-z0-9._:-]+$" },
    "aft_event_version": { "type": "string", "pattern": "^0\\.1(\\.\\d+)?$" },
    "event_type": { "$ref": "#/$defs/eventType" },
    "event_time": { "type": "string", "format": "date-time" },
    "agent_id": { "$ref": "#/$defs/agentId" },
    "principal_id": { "$ref": "#/$defs/entityId" },
    "operator_id": { "$ref": "#/$defs/entityId" },
    "counterparty_id": { "$ref": "#/$defs/entityId" },
    "transaction": { "$ref": "#/$defs/transaction" },
    "authority": { "$ref": "#/$defs/authority" },
    "evidence": { "$ref": "#/$defs/evidence" },
    "privacy": { "$ref": "#/$defs/privacy" },
    "blockchain_anchor": { "$ref": "#/$defs/blockchainAnchor" },
    "crypto": { "$ref": "#/$defs/crypto" },
    "signatures": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/signature" }
    },
    "correlation": { "$ref": "#/$defs/correlation" },
    "supersedes_event_id": { "type": "string", "pattern": "^aft:event:[A-Za-z0-9._:-]+$" }
  },
  "$defs": {
    "agentId": {
      "type": "string",
      "pattern": "^aft:agent:[A-Za-z0-9._:-]+$"
    },
    "entityId": {
      "type": "string",
      "pattern": "^(aft:(principal|owner|operator|controller|counterparty|issuer|lender|arbitrator|processor):[A-Za-z0-9._:-]+|did:[a-z0-9]+:.+)$"
    },
    "hashRef": {
      "type": "string",
      "pattern": "^sha(256|384|512):[A-Fa-f0-9]{64,128}$"
    },
    "eventType": {
      "type": "string",
      "enum": [
        "AGENT_PAYMENT_INITIATED",
        "AGENT_PAYMENT_AUTHORIZED",
        "AGENT_PAYMENT_SETTLED",
        "AGENT_PAYMENT_FAILED",
        "AGENT_PAYMENT_REVERSED",
        "AGENT_PAYMENT_REFUNDED",
        "AGENT_PAYMENT_CHARGEBACK_OPENED",
        "AGENT_PAYMENT_CHARGEBACK_RESOLVED",
        "AGENT_INVOICE_ISSUED",
        "AGENT_INVOICE_ACCEPTED",
        "AGENT_INVOICE_PAID",
        "AGENT_INVOICE_LATE",
        "AGENT_INVOICE_DEFAULTED",
        "AGENT_OBLIGATION_CREATED",
        "AGENT_OBLIGATION_FULFILLED",
        "AGENT_OBLIGATION_BREACHED",
        "AGENT_ESCROW_FUNDED",
        "AGENT_ESCROW_RELEASED",
        "AGENT_ESCROW_DISPUTED",
        "AGENT_ESCROW_REFUNDED",
        "AGENT_ESCROW_ARBITRATED",
        "AGENT_CREDIT_LINE_ISSUED",
        "AGENT_CREDIT_LIMIT_UPDATED",
        "AGENT_CREDIT_UTILIZED",
        "AGENT_CREDIT_REPAID",
        "AGENT_CREDIT_LATE",
        "AGENT_CREDIT_DEFAULTED",
        "AGENT_CREDIT_SUSPENDED",
        "AGENT_SECURITY_INCIDENT_REPORTED",
        "AGENT_KEY_COMPROMISE_REPORTED",
        "AGENT_PROMPT_INJECTION_PAYMENT_ATTEMPT",
        "AGENT_UNAUTHORIZED_PAYMENT_ATTEMPT",
        "AGENT_IMPERSONATION_CLAIMED",
        "AGENT_IMPERSONATION_CONFIRMED",
        "AGENT_FRAUD_REPORT_FILED",
        "AGENT_FRAUD_REPORT_VALIDATED",
        "AGENT_FRAUD_REPORT_REJECTED",
        "AGENT_POLICY_VIOLATION_RECORDED",
        "AGENT_REPUTATION_ATTESTED",
        "AGENT_REPUTATION_ROOT_UPDATED",
        "AGENT_TRUST_TIER_UPDATED",
        "AGENT_BOND_STAKED",
        "AGENT_BOND_SLASHED",
        "AGENT_CERTIFICATION_ISSUED",
        "AGENT_CERTIFICATION_REVOKED"
      ]
    },
    "amount": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "currency"],
      "properties": {
        "value": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]{1,18})?$" },
        "currency": { "type": "string", "pattern": "^[A-Z0-9]{3,12}$" }
      }
    },
    "transaction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["transaction_id", "transaction_type", "status"],
      "properties": {
        "transaction_id": { "type": "string", "minLength": 1 },
        "transaction_type": { "type": "string", "enum": ["PAYMENT", "INVOICE", "OBLIGATION", "ESCROW", "CREDIT", "SECURITY", "REPUTATION", "DISPUTE", "INCIDENT"] },
        "status": { "type": "string", "enum": ["INITIATED", "AUTHORIZED", "SETTLED", "FAILED", "REVERSED", "REFUNDED", "OPEN", "RESOLVED", "REPORTED", "ISSUED", "UTILIZED", "REPAID", "SUSPENDED", "UNKNOWN"] },
        "amount": { "$ref": "#/$defs/amount" },
        "asset_type": { "type": "string", "enum": ["FIAT", "STABLECOIN", "CRYPTO", "CREDIT", "NON_MONETARY"] },
        "payment_protocol": { "type": "string", "enum": ["X402", "AP2", "ACP", "CARD", "ACH", "BANK", "STABLECOIN", "SMART_CONTRACT", "NONE", "OTHER"] },
        "rail_ref": { "type": "string", "minLength": 1 },
        "settlement_id": { "type": "string", "minLength": 1 },
        "purpose_code": { "type": "string", "minLength": 1 },
        "external_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mandate_id", "mandate_type", "mandate_hash", "principal_id", "agent_id", "authorized"],
      "properties": {
        "mandate_id": { "type": "string", "pattern": "^aft:mandate:[A-Za-z0-9._:-]+$" },
        "mandate_type": {
          "type": "string",
          "enum": [
            "LOW_VALUE_API_PURCHASE",
            "AP2_INTENT_MANDATE",
            "AP2_CART_MANDATE",
            "AP2_PAYMENT_MANDATE",
            "HUMAN_CONFIRMED_PAYMENT",
            "AUTONOMOUS_BUDGET",
            "RECURRING_SERVICE_PAYMENT",
            "PROCUREMENT_AUTHORITY",
            "ESCROW_RELEASE_AUTHORITY",
            "CREDIT_UTILIZATION_AUTHORITY",
            "CUSTOM"
          ]
        },
        "mandate_hash": { "$ref": "#/$defs/hashRef" },
        "principal_id": { "$ref": "#/$defs/entityId" },
        "agent_id": { "$ref": "#/$defs/agentId" },
        "authorized": { "type": "boolean" },
        "scope": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "amount_limit": { "$ref": "#/$defs/amount" },
        "expires_at": { "type": "string", "format": "date-time" },
        "nonce": { "type": "string", "minLength": 8 },
        "policy_ref": { "type": "string", "minLength": 1 },
        "revocation_ref": { "type": "string", "minLength": 1 }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_type", "evidence_hashes", "redaction_status"],
      "properties": {
        "evidence_type": { "type": "string", "enum": ["RECEIPT", "MANDATE", "INVOICE", "DISPUTE", "INCIDENT", "CREDIT", "ANCHOR", "REPUTATION", "OTHER"] },
        "evidence_hashes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/hashRef" }
        },
        "evidence_uri": { "type": "string", "minLength": 1 },
        "receipt_hash": { "$ref": "#/$defs/hashRef" },
        "external_evidence_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "redaction_status": { "type": "string", "enum": ["NONE", "REDACTED", "SELECTIVE_DISCLOSURE", "HASH_ONLY"] }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["classification", "pii_present", "on_chain_disclosure", "retention_policy"],
      "properties": {
        "classification": { "type": "string", "enum": ["PUBLIC", "PRIVATE", "RESTRICTED", "HASH_ONLY"] },
        "pii_present": { "type": "boolean" },
        "on_chain_disclosure": {
          "type": "array",
          "items": { "type": "string", "enum": ["EVENT_HASH", "MERKLE_ROOT", "REVOCATION_ROOT", "REPUTATION_ROOT", "DISPUTE_COMMITMENT", "BOND_STATE", "REGISTRY_POINTER", "CREDENTIAL_HASH"] }
        },
        "selective_disclosure": { "type": "boolean" },
        "retention_policy": { "type": "string", "minLength": 1 }
      }
    },
    "blockchainAnchor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["batch_id", "chain_id", "batch_root", "event_leaf_hash", "anchored_at"],
      "properties": {
        "batch_id": { "type": "string", "pattern": "^aft:batch:[A-Za-z0-9._:-]+$" },
        "chain_id": { "type": "string", "minLength": 1 },
        "network": { "type": "string", "minLength": 1 },
        "transaction_ref": { "type": "string", "minLength": 1 },
        "batch_root": { "$ref": "#/$defs/hashRef" },
        "event_leaf_hash": { "$ref": "#/$defs/hashRef" },
        "inclusion_proof_ref": { "type": "string", "minLength": 1 },
        "anchored_at": { "type": "string", "format": "date-time" }
      }
    },
    "crypto": {
      "type": "object",
      "additionalProperties": false,
      "required": ["canonicalization", "digest_alg", "event_hash", "pqc_profile", "signature_input"],
      "properties": {
        "canonicalization": { "type": "string", "enum": ["JCS-RFC8785", "AFT-JCS-DRAFT-0.1"] },
        "digest_alg": { "type": "string", "enum": ["SHA-256", "SHA-384", "SHA-512"] },
        "event_hash": { "$ref": "#/$defs/hashRef" },
        "pqc_profile": { "$ref": "#/$defs/pqcProfile" },
        "signature_input": { "type": "string", "minLength": 1 }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["alg", "kid", "key_version", "pqc_profile", "signature_value", "signature_created_at", "verification_method"],
      "properties": {
        "alg": { "$ref": "#/$defs/signatureAlg" },
        "kid": { "type": "string", "minLength": 1 },
        "key_version": { "type": "integer", "minimum": 1 },
        "pqc_profile": { "$ref": "#/$defs/pqcProfile" },
        "signature_value": { "type": "string", "pattern": "^[A-Za-z0-9_-]+={0,2}$" },
        "signature_created_at": { "type": "string", "format": "date-time" },
        "signature_expires_at": { "type": "string", "format": "date-time" },
        "verification_method": { "type": "string", "minLength": 1 }
      }
    },
    "correlation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "correlation_id": { "type": "string", "minLength": 1 },
        "causation_event_id": { "type": "string", "pattern": "^aft:event:[A-Za-z0-9._:-]+$" },
        "related_event_ids": {
          "type": "array",
          "items": { "type": "string", "pattern": "^aft:event:[A-Za-z0-9._:-]+$" }
        },
        "external_reference_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "workflow_id": { "type": "string", "minLength": 1 }
      }
    },
    "signatureAlg": {
      "type": "string",
      "enum": [
        "aft-sig-ed25519-legacy",
        "aft-sig-ecdsa-p256-legacy",
        "aft-sig-ml-dsa",
        "aft-sig-slh-dsa",
        "aft-sig-hybrid-ed25519-ml-dsa",
        "aft-sig-hybrid-ecdsa-ml-dsa"
      ]
    },
    "pqcProfile": {
      "type": "string",
      "enum": ["AFT-PQC-0", "AFT-PQC-1", "AFT-PQC-2", "AFT-PQC-3", "AFT-PQC-4", "AFT-PQC-5"]
    }
  }
}
