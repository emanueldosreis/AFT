{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aftprotocol.org/schemas/draft/0.1/aft-crypto-profile.schema.json",
  "title": "AFT Crypto Profile",
  "description": "Crypto-agility and post-quantum readiness profile for an AFT implementation or agent.",
  "type": "object",
  "additionalProperties": false,
  "required": ["profile_id", "subject_id", "pqc_readiness", "signature_profiles", "kem_profiles", "hash_profiles", "keys", "rotation_policy", "deprecation_policy", "signature"],
  "properties": {
    "profile_id": { "type": "string", "pattern": "^aft:crypto-profile:[A-Za-z0-9._:-]+$" },
    "subject_id": {
      "type": "string",
      "pattern": "^(aft:agent:[A-Za-z0-9._:-]+|aft:(principal|operator|controller|issuer):[A-Za-z0-9._:-]+|did:[a-z0-9]+:.+)$"
    },
    "pqc_readiness": { "$ref": "#/$defs/pqcProfile" },
    "signature_profiles": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/signatureAlg" }
    },
    "kem_profiles": {
      "type": "array",
      "items": { "type": "string", "enum": ["aft-kem-ml-kem", "aft-kem-hybrid-ecdh-ml-kem"] }
    },
    "hash_profiles": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "enum": ["SHA-256", "SHA-384", "SHA-512"] }
    },
    "keys": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kid", "alg", "key_version", "status", "created_at", "verification_method"],
        "properties": {
          "kid": { "type": "string", "minLength": 1 },
          "alg": { "$ref": "#/$defs/signatureAlg" },
          "key_version": { "type": "integer", "minimum": 1 },
          "status": { "type": "string", "enum": ["ACTIVE", "TRANSITIONAL", "DEPRECATED", "REVOKED"] },
          "created_at": { "type": "string", "format": "date-time" },
          "expires_at": { "type": "string", "format": "date-time" },
          "verification_method": { "type": "string", "minLength": 1 }
        }
      }
    },
    "rotation_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maximum_key_age_days", "supports_emergency_rotation", "last_tested_at"],
      "properties": {
        "maximum_key_age_days": { "type": "integer", "minimum": 1 },
        "supports_emergency_rotation": { "type": "boolean" },
        "last_tested_at": { "type": "string", "format": "date-time" }
      }
    },
    "deprecation_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm_status_registry", "classical_only_new_event_deadline"],
      "properties": {
        "algorithm_status_registry": { "type": "string", "minLength": 1 },
        "classical_only_new_event_deadline": { "type": "string", "format": "date-time" },
        "emergency_disable_supported": { "type": "boolean" }
      }
    },
    "signature": { "$ref": "#/$defs/signature" }
  },
  "$defs": {
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["alg", "kid", "key_version", "pqc_profile", "signature_value", "signature_created_at", "verification_method"],
      "properties": {
        "alg": { "$ref": "#/$defs/signatureAlg" },
        "kid": { "type": "string", "minLength": 1 },
        "key_version": { "type": "integer", "minimum": 1 },
        "pqc_profile": { "$ref": "#/$defs/pqcProfile" },
        "signature_value": { "type": "string", "pattern": "^[A-Za-z0-9_-]+={0,2}$" },
        "signature_created_at": { "type": "string", "format": "date-time" },
        "signature_expires_at": { "type": "string", "format": "date-time" },
        "verification_method": { "type": "string", "minLength": 1 }
      }
    },
    "signatureAlg": {
      "type": "string",
      "enum": ["aft-sig-ed25519-legacy", "aft-sig-ecdsa-p256-legacy", "aft-sig-ml-dsa", "aft-sig-slh-dsa", "aft-sig-hybrid-ed25519-ml-dsa", "aft-sig-hybrid-ecdsa-ml-dsa"]
    },
    "pqcProfile": {
      "type": "string",
      "enum": ["AFT-PQC-0", "AFT-PQC-1", "AFT-PQC-2", "AFT-PQC-3", "AFT-PQC-4", "AFT-PQC-5"]
    }
  }
}
